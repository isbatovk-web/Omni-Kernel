#!/bin/bash

# Omni-Kernel Unix Installer (Bash)
REPO_URL="https://github.com/isbatovk-web/Omni-Kernel.git"
INSTALL_DIR="$HOME/Omni-Kernel"

echo -e "\e[36m⚡ Omni-Kernel Installer starting...\e[0m"

# 1. Dependency Check
if ! command -v git &> /dev/null; then
    echo -e "\e[31m❌ Error: Git is not installed.\e[0m"
    exit 1
fi

if ! command -v cargo &> /dev/null; then
    echo -e "\e[31m❌ Error: Rust/Cargo is not installed. Visit https://rustup.rs\e[0m"
    exit 1
fi

# 2. Download and Install Pre-compiled Binary
RELEASE_URL="https://github.com/isbatovk-web/Omni-Kernel/releases/download/v1.0.4/omni-kernel-linux.tar.gz"

if [[ "$OSTYPE" == "darwin"* ]]; then
    RELEASE_URL="https://github.com/isbatovk-web/Omni-Kernel/releases/download/v1.0.4/omni-kernel-mac.tar.gz"
fi

echo -e "\e[36m🚀 Downloading Universal Logic Fabric...\e[0m"
mkdir -p "$INSTALL_DIR"
curl -L "$RELEASE_URL" -o "$INSTALL_DIR/omni.tar.gz"

if [ $? -ne 0 ]; then
    echo -e "\e[31m❌ Error: Download failed. Release might not be published yet.\e[0m"
    exit 1
fi

echo -e "\e[36m📦 Unpacking Engine...\e[0m"
tar -xzf "$INSTALL_DIR/omni.tar.gz" -C "$INSTALL_DIR"
rm "$INSTALL_DIR/omni.tar.gz"

# 3. Finalization
echo -e "\n\e[32m✅ Omni-Kernel Engine Grounded in < 5 Seconds!\e[0m"
echo -e "\e[33m👉 To start: cd ~/Omni-Kernel && ./omni-kernel\e[0m"
